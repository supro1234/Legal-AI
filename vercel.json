{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/analyze",
      "destination": "/server/index.js"
    },
    {
      "source": "/test-connection",
      "destination": "/server/index.js"
    },
    {
      "source": "/health",
      "destination": "/server/index.js"
    },
    {
      "source": "/",
      "destination": "/popup/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
